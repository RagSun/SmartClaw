# ==============================================
# SmartClaw 生产环境配置示例
# ==============================================
# 使用说明：
# 1. 复制本文件为 .env: cp .env.example .env
# 2. 填写所有必需的配置项（标有 [必需] 的项）
# 3. 根据实际环境调整可选配置项
#
# 配置优先级：.env 环境变量 > config.toml > 默认值
# 即 .env 中设置的值会覆盖 TOML 配置文件中的同名字段。
# 启动时 .env 自动加载（通过 python-dotenv），搜索顺序：
#   $SMARTCLAW_DOTENV_PATH → 项目根目录/.env → 当前目录/.env
# ==============================================

# ==============================================
# LLM 配置 [必需]
# ==============================================
# LLM 服务提供商（支持: openai, anthropic, deepseek 等）
LLM_PROVIDER=deepseek

# LLM API 密钥 [必需]
# 获取方式:
# - deepseek AI: https://www.deepseek.com/
# - OpenAI: https://platform.openai.com/
LLM_API_KEY=your_llm_api_key_here

# LLM 模型名称
# deepseek AI示例: deepseek-v4-flash
# OpenAI示例: gpt-4
LLM_MODEL=deepseek-v4-flash

# LLM API 基础 URL
# deepseek AI: https://api.deepseek.com/v1
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 最大 token 数
LLM_MAX_TOKENS=8192

# 温度参数（0.0-2.0，越高越随机）
LLM_TEMPERATURE=0.7

# ==============================================
# Vision/图像识别配置 [可选]
# ==============================================
# 是否启用视觉功能
VISION_ENABLED=false

# Vision API 密钥（如使用与 LLM 相同的密钥，可留空）
VISION_API_KEY=

# Vision 模型名称
VISION_MODEL=qwen3.7-plus

# Vision API 基础 URL
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 超时时间（秒）
VISION_TIMEOUT=60

# 最大重试次数
VISION_MAX_RETRIES=3

# ==============================================
# 飞书渠道配置 [可选]
# ==============================================
# 飞书应用 ID [使用飞书时必需]
# 获取方式: https://open.feishu.cn/app
FEISHU_APP_ID=cli_your_feishu_app_id

# 飞书应用密钥 [使用飞书时必需]
FEISHU_APP_SECRET=

# 飞书加密密钥（如果启用了加密）
FEISHU_ENCRYPT_KEY=

# 飞书验证令牌（如果需要）
FEISHU_VERIFICATION_TOKEN=

# ==============================================
# 企业微信渠道配置 [可选]
# ==============================================
# 企业微信渠道是否启用（1/true/yes/on 启用，0/false 关闭）
WECOM_ENABLED=false

# 企业微信 CorpID [使用企业微信时必需]
# 获取方式: https://work.weixin.qq.com/
WECOM_CORP_ID=

# 企业微信应用 Secret
WECOM_APP_SECRET=

# 企业微信应用 ID
WECOM_AGENT_ID=

# ==============================================
# 沙箱/容器配置 [可选]
# ==============================================
# 是否启用沙箱隔离
SANDBOX_ENABLED=true

# 沙箱类型（docker, firecracker）
SANDBOX_TYPE=docker

# 容器内存限制（MB）
SANDBOX_MEMORY_MB=128

# 容器 CPU 核心数
SANDBOX_CPU_COUNT=1

# ==============================================
# 服务器配置 [可选]
# ==============================================
# 服务器监听地址
SERVER_HOST=0.0.0.0

# 服务器端口
SERVER_PORT=8000

# 工作进程数
SERVER_WORKERS=4

# ==============================================
# 日志配置 [可选]
# ==============================================
# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/opt/smartclaw/logs/smartclaw.log

# 日志文件大小限制（MB）
LOG_MAX_BYTES=10

# 日志备份数量
LOG_BACKUP_COUNT=5

# ==============================================
# 数据库配置 [可选]
# ==============================================
# 数据库类型（sqlite, mysql, postgresql）
DATABASE_TYPE=sqlite

# SQLite 数据库路径
DATABASE_PATH=/opt/smartclaw/data/smartclaw.db

# MySQL/PostgreSQL 连接信息（如果使用）
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=smartclaw
DATABASE_USER=smartclaw
DATABASE_PASSWORD=

# ==============================================
# 安全配置 [可选]
# ==============================================
# 管理面 /api/admin/* 专用 Bearer 凭证（与监控凭证隔离，最小权限）[生产强烈建议]
# 默认安全：未设置时管理面（租户开通/停用/删除）默认拒绝一切匿名访问。
# docker-compose 会强制要求设置该值后才允许部署。
SMARTCLAW_ADMIN_TOKEN=change_this_to_a_long_random_secret
# 管理面是否要求鉴权（默认 true=安全；仅在可信内网/网关后才考虑关闭）
SMARTCLAW_ADMIN_REQUIRE_AUTH=true

# API 密钥（用于服务间通信）
API_SECRET_KEY=your_api_secret_key_change_this

# 允许的主机（CORS 配置）
ALLOWED_HOSTS=*

# 会话超时时间（秒）
SESSION_TIMEOUT=3600

# ==============================================
# 监控配置 [可选]
# ==============================================
# 是否启用监控
MONITORING_ENABLED=false

# 监控数据保留时间（天）
MONITORING_RETENTION_DAYS=7

# ==============================================
# 开发模式配置 [可选]
# ==============================================
# 是否启用开发模式（自动重载、详细日志等）
DEBUG=false

# 开发模式下的热重载
RELOAD=false

# ==============================================
# 高级配置 [一般不需要修改]
# ==============================================
# 事件总线目录
EVENT_BUS_DIR=~/.smartclaw/event-bus

# 子代理状态目录
SUBAGENT_STATE_DIR=~/.smartclaw/subagent-state

# 工具目录
TOOLS_DIR=tools

# 配置目录
CONFIG_DIR=/opt/smartclaw/config

# 数据目录
DATA_DIR=/opt/smartclaw/data

# 日志目录
LOG_DIR=/opt/smartclaw/logs
