[llm]
provider = "deepseek"
model = "deepseek-v4-flash"
base_url = "https://api.deepseek.com/v1"
api_key = ""
max_tokens = 8192
temperature = 0.7

[vision]
enabled = false
model = "qwen3.7-plus"
base_url = "https://dashscope.aliyuncs.com/compatible-mode/v1"
api_key = ""
timeout = 60
max_retries = 3

[channels.feishu]
# 易用：仅填一对凭证即可（自动生成 accounts.default，适合单机器人 / 与长连接向导一致）
enabled = true
app_id = ""
app_secret = ""
# encrypt_key = ""  # 事件订阅开启加密时填写
# 多机器人请改用 accounts 块，例如：
# default = "bot1"
# [channels.feishu.accounts.bot1]
# app_id = "cli_xxx"
# app_secret = "yyy"

[sandbox]
enabled = true
memory_mb = 128
cpu_count = 1

[server]
host = "0.0.0.0"
port = 8000
workers = 4
# 边缘防护：HTTP 请求体大小上限（字节），超过即 413；0 = 不限制。默认 1 MiB。
max_request_bytes = 1048576

[logging]
level = "INFO"
file = "/opt/smartclaw/logs/smartclaw.log"

[skills]
allowlist = []
blocked_risk_levels = []
require_approval_for = ["high", "critical"]
security_allowlist_skill_keys = []

[skills.load]
extra_dirs = []
watch = false
watch_debounce_ms = 250

[skills.install]
prefer_brew = true
node_manager = "npm"

[skills.limits]
max_skills_in_prompt = 80
max_skills_prompt_chars = 20000
max_skill_file_bytes = 256000

[execution]
# 统一执行引擎 / Planner / DeepAgents 开关（原子字段，见 docs/smartclaw_CLI_命令手册.md §5.4）
use_unified_engine = true
deepagents_enabled = true
react_fallback_enabled = true
llm_tool_fallback_enabled = true
planner_first_enabled = true
emit_structured_trace = true
# DeepAgents / LangGraph 单轮最大图步数（参考 OpenClaw 等对循环与上下文的硬约束）；0 = 不限制（慎用）
deepagents_recursion_limit = 128

# 宿主 exec 白名单（全局层）：与 agent.json「shell_allowlist」、工作区 tools/SHELL_ALLOWLIST.txt 并集合并；全非空合并后才启用匹配层
# shell_allowlist = ["python", "pip", "git"]
# 可选外挂文件，每行一条规则，UTF-8，# 为注释；路径可含 ~
# shell_allowlist_path = ""

[auth]
monitoring_require_auth = false
monitoring_bearer_token = ""
monitoring_jwt_enabled = false
monitoring_jwt_algorithm = "HS256"
monitoring_jwt_secret = ""
monitoring_jwt_audience = ""
monitoring_jwt_issuer = ""
# —— 管理面 /api/admin/* 鉴权（默认安全，与监控凭证隔离）——
# admin_require_auth=true（默认）：即便监控鉴权关闭，租户开通/停用/删除仍要求鉴权。
# 未配 admin_bearer_token 且监控鉴权也关闭时 → 管理面默认拒绝一切（secure by default）。
# 生产请用环境变量注入凭证（SMARTCLAW_ADMIN_TOKEN），勿明文入库。
admin_require_auth = true
admin_bearer_token = ""
feishu_webhook_secret = ""
feishu_decrypt_webhook = true
tenant_default = "default"
tenant_trust_header = false
webhook_replay_ttl_seconds = 0
# [auth.tenant_by_app_id]
# "cli_xxx" = "tenant-a"

[platform]
event_bus_enabled = false
event_bus_dir = ""

# LangSmith / LangChain 追踪：加载 config 后写入 LANGCHAIN_*（不覆盖已有环境变量）。也可用 CLI：smartclaw config langsmith --help
[langsmith]
enabled = false
api_key = ""
# project = "my-project"
# endpoint = "https://api.smith.langchain.com"

# 记忆数据面后端（见 progress.md §12）。
#   store = "sqlite"   ：按 agent 分文件（默认，单机 / 共享卷部署）
#   store = "postgres" ：共享库，多实例一致（同一对话可由任意副本处理）
# 也可用环境变量覆盖（容器/compose 注入）：
#   SMARTCLAW_MEMORY_STORE / SMARTCLAW_MEMORY_POSTGRES_DSN
[memory]
store = "sqlite"
# postgres_dsn = "postgresql://user:password@host:5432/smartclaw"

# 租户/用户资源治理（限流 / 配额 / 并发）。默认 enabled=false，整层旁路。
# 判定自顶向下、任一超限即拒：① 租户停用 ② 租户配额/限流 ③ 用户配额/限流。
# 每维度 0=不限；per_* 中省略字段=继承同名默认。
# [governance]
# enabled = false
# store = "memory"                      # 多副本一致改为 "redis"
# redis_url = "redis://127.0.0.1:6379/0"
# # —— 租户级（管钱 / 天花板）——
# default_daily_token_quota = 0
# default_rate_per_min = 0
# default_max_concurrency = 0
# # —— 用户级（管公平 / 防单人刷爆；纯增量，全 0 时等于关闭）——
# default_user_daily_token_quota = 0
# default_user_rate_per_min = 0
# default_user_max_concurrency = 0
# [governance.per_tenant.tenant-a]
# daily_token_quota = 5000000
# [governance.per_user_by_tenant.tenant-a]
# "ou_boss_open_id" = { daily_token_quota = 0 }       # 0=不限
# "ou_intern_open_id" = { daily_token_quota = 20000 } # 单用户收紧
